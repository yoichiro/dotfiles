# Template for ~/.envs.local
#
# Copy this file to ~/.envs.local and edit it for the current machine.
# This file is sourced from `envs` at the very end, so it can append to or
# override anything defined in `envs`.
#
#   cp ~/.dotfiles/envs.local.example ~/.envs.local
#
# Use this file for any machine-specific environment variables, including
# secrets (API keys, tokens). When you put secrets here, lock the file down:
#
#   chmod 600 ~/.envs.local

# ===== MCP server credentials =====
# Naming convention: MCP_<SERVER>_<KIND> (so all MCP-related tokens cluster).
# Consumed by ~/.dotfiles/claude/mcp-setup.sh; missing values cause that
# script to abort early with a clear error.

# Slack MCP server (browser-extracted xoxc/xoxd token pair).
# export MCP_SLACK_XOXC_TOKEN=""
# export MCP_SLACK_XOXD_TOKEN=""

# GitHub MCP server: Personal Access Token.
# export MCP_GITHUB_PAT=""

# inter-agent-bus MCP server: Bearer token for the iab_ scheme.
# export MCP_IAB_TOKEN=""

# activity-reporting (Advocu) MCP server access token.
# export MCP_ADVOCU_TOKEN=""

# google-developer-knowledge MCP server: X-Goog-Api-Key value.
# export MCP_GDK_API_KEY=""

# ===== Other tool credentials =====

# GitHub PAT used by the Gemini CLI (NOT by the github MCP server above).
# export GEMINI_GITHUB_PAT=""

# ===== Other examples =====

# --- Override the default editor on this machine ---
# export EDITOR="code --wait"

# --- Project / tool specific defaults ---
# export GOOGLE_CLOUD_PROJECT="my-project-id"

# --- Locale tweaks ---
# export LANG="en_US.UTF-8"
